# Hackathon API key (from organizers) — no spaces around =
ANTHROPIC_API_KEY=your-hackathon-key-here

# Hackathon LiteLLM gateway (from organizers) — root URL only, no /v1
ANTHROPIC_BASE_URL=https://litellm.rapidscreen.io

# Neon Postgres connection string — no spaces around =
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional on Vercel — when set, mutating API routes require this secret in the unlock banner. Leave unset for open hackathon demo.
SHOPLOG_WRITE_SECRET=
